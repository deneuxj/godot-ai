[gd_scene load_steps=2 format=3 uid="uid://ai-chat-panel-scene"]

[ext_resource type="Script" uid="uid://ai-chat-panel-script" path="res://addons/ai_assistant/ai_chat_panel.gd" id="1_panel"]

[node name="AIChatPanel" type="ScrollContainer"]
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
