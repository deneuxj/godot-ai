"function": {
"arguments": "{\"script_content\":\"static func execute(node: Node) -> String:\\n\\tvar tree = node.get_tree()\\n\\tvar current_scene = tree.current_scene\\n\\t\\n\\tif current_scene is Node:\\n\\t\\tvar root_node = current_scene\\n\\t\\treturn \\\"Root node name: \\\" + str(root_node.name)\\n\\telse:\\n\\t\\treturn \\\"Current scene: \\\" + str(current_scene)\"}",
