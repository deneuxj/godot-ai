"arguments": "{\"script_content\":\"static func execute(node: Node):\\n\\t# Remove existing Closet node if present\\n\\tvar existing_closet = node.get_node_or_null(\\\"Closet\\\")\\n\\tif existing_closet:\\n\\t\\texisting_closet.queue_free()\\n\\t\\n\\tvar closet = Node3D.new()\\n\\tcloset.name = \\\"Closet\\\"\\n\\t\\n\\t# Closet dimensions from blueprint\\n\\tvar internal_thickness = 0.10\\n\\tvar external_thickness = 0.50\\n\\tvar wall_height = 2.00\\n\\tvar room_width = 4.74   # X direction: from 5.99 to 10.73\\n\\tvar room_depth = 2.00   # Z direction: from 5.249 to 7.249\\n\\t\\n\\t# Position: starts at (5.99, 5.249) in blueprint coordinates\\n\\tvar x_start = 5.99\\n\\tvar z_start = 5.249\\n\\t\\n\\t# Wall material (light gray)\\n\\tvar mat = StandardMaterial3D.new()\\n\\tmat.albedo_color = Color(0.7, 0.7, 0.7)\\n\\t\\n\\t# Left Wall: Internal wall at X=5.99, from Z=5.249 to Z=7.249\\n\\tvar left_pos = Vector3(x_start - internal_thickness / 2, wall_height / 2, z_start + room_depth / 2)\\n\\tvar left_size = Vector3(internal_thickness, wall_height, room_depth)\\n\\tvar left_wall = _create_wall(\\\"Left_Wall\\\", left_pos, left_size, mat)\\n\\tcloset.add_child(left_wall)\\n\\t\\n\\t# Right Wall: Internal wall at X=10.73, from Z=5.249 to Z=7.249\\n\\tvar right_pos = Vector3(x_start + room_width + internal_thickness / 2, wall_height / 2, z_start + room_depth / 2)\\n\\tvar right_size = Vector3(internal_thickness, wall_height, room_depth)\\n\\tvar right_wall = _create_wall(\\\"Right_Wall\\\", right_pos, right_size, mat)\\n\\tcloset.add_child(right_wall)\\n\\t\\n\\t# Bottom Wall: Internal wall at Z=5.249, from X=5.99 to X=10.73\\n\\tvar bottom_pos = Vector3(x_start + room_width / 2, wall_height / 2, z_start - internal_thickness / 2)\\n\\tvar bottom_size = Vector3(room_width, wall_height, internal_thickness)\\n\\tvar bottom_wall = _create_wall(\\\"Bottom_Wall\\\", bottom_pos, bottom_size, mat)\\n\\tcloset.add_child(bottom_wall)\\n\\t\\n\\t# Top Wall: External wall at Z=7.249, from X=5.99 to X=10.73\\n\\tvar top_pos = Vector3(x_start + room_width / 2, wall_height / 2, z_start + room_depth + external_thickness / 2)\\n\\tvar top_size = Vector3(room_width, wall_height, external_thickness)\\n\\tvar top_wall = _create_wall(\\\"Top_Wall\\\", top_pos, top_size, mat)\\n\\tcloset.add_child(top_wall)\\n\\t\\n\\t# Add Closet to the context node\\n\\tnode.add_child(closet)\\n\\t\\n\\t# Set owners for all nodes\\n\\tcloset.owner = node\\n\\tleft_wall.owner = node\\n\\tright_wall.owner = node\\n\\tbottom_wall.owner = node\\n\\ttop_wall.owner = node\\n\\t\\n\\tprint(\\\"Closet node added to scene!\\\")\\n\\n\\nstatic func _create_wall(name: String, pos: Vector3, size: Vector3, material: StandardMaterial3D) -> StaticBody3D:\\n\\tvar wall := StaticBody3D.new()\\n\\twall.name = name\\n\\twall.position = pos\\n\\t\\n\\tvar mesh_inst := MeshInstance3D.new()\\n\\tvar box_mesh := BoxMesh.new()\\n\\tbox_mesh.set_size(size)\\n\\tmesh_inst.mesh = box_mesh\\n\\tmesh_inst.material_override = material\\n\\twall.add_child(mesh_inst)\\n\\t\\n\\tvar col_shape := CollisionShape3D.new()\\n\\tvar box_shape := BoxShape3D.new()\\n\\tbox_shape.set_size(size)\\n\\tcol_shape.shape = box_shape\\n\\twall.add_child(col_shape)\\n\\t\\n\\treturn wall\"}",
"name": "execute_script"
},
"id": "901239531",
"type": "function"
}]
