(t_bottom)\\n\\t\\n\\t# Top Wall: External\\n\\t# Runs along X, Z=7.249\\n\\tvar t_top = _create_wall(\\\"Top_Wall\\\", Vector3(10.73 + 2.37, terrace_height/2, 7.249 + terrace_external_thickness/2), Vector3(4.74, terrace_height, terrace_external_thickness), terrace_mat)\\n\\tterrace_walls.append(t_top)\\n\\tterrace.add_child(t_top)\\n\\t\\n\\tnode.add_child(terrace)\\n\\tterrace.owner = target_owner\\n\\tfor w in terrace_walls:\\n\\t\\tw.owner = target_owner\\n\\t\\tfor c in w.get_children(): c.owner = target_owner\\n\\t\\n\\tprint(\\\"Terrace implemented correctly!\\\")\\n\\n\\nstatic func _create_wall(name: String, pos: Vector3, size: Vector3, material: StandardMaterial3D) -> StaticBody3D:\\n\\tvar wall := StaticBody3D.new()\\n\\twall.name = name\\n\\twall.position = pos\\n\\t\\n\\tvar mesh_inst := MeshInstance3D.new()\\n\\tvar box_mesh := BoxMesh.new()\\n\\tbox_mesh.set_size(size)\\n\\tmesh_inst.mesh = box_mesh\\n\\tmesh_inst.material_override = material\\n\\twall.add_child(mesh_inst)\\n\\t\\n\\tvar col_shape := CollisionShape3D.new()\\n\\tvar box_shape := BoxShape3D.new()\\n\\tbox_shape.set_size(size)\\n\\tcol_shape.shape = box_shape\\n\\twall.add_child(col_shape)\\n\\t\\n\\treturn wall\"}",
