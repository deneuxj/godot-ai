[gd_scene load_steps=3 format=3 uid="uid://de4chat-test-scene"]

[ext_resource type="Script" uid="uid://test-ai-chat-scene-script" path="res://test_ai_chat_scene.gd" id="1_script"]
[ext_resource type="Script" uid="uid://ai-chat-node-script" path="res://addons/ai_assistant/ai_chat.gd" id="2_chat"]

[node name="TestAIChat" type="Control"]
layout_fill = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
script = ExtResource("1_script")

[node name="AIChat" type="Node" parent="."]
script = ExtResource("2_chat")
system_prompt = "You are a helpful Godot Engine assistant. You help users with GDScript, node organization, and engine features. Keep your responses concise and technically accurate."

[node name="Panel" type="Panel" parent="."]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2

[node name="MarginContainer" type="MarginContainer" parent="Panel"]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
theme_override_constants/margin_left = 20
theme_override_constants/margin_top = 20
theme_override_constants/margin_right = 20
theme_override_constants/margin_bottom = 20

[node name="VBoxContainer" type="VBoxContainer" parent="Panel/MarginContainer"]
layout_mode = 2
theme_override_constants/separation = 10

[node name="Header" type="HBoxContainer" parent="Panel/MarginContainer/VBoxContainer"]
layout_mode = 2

[node name="Title" type="Label" parent="Panel/MarginContainer/VBoxContainer/Header"]
layout_mode = 2
size_flags_horizontal = 3
theme_override_font_sizes/font_size = 24
text = "AI Chat Test"

[node name="ClearButton" type="Button" parent="Panel/MarginContainer/VBoxContainer/Header"]
unique_name_in_owner = true
layout_mode = 2
text = "Clear History"

[node name="HistoryDisplay" type="RichTextLabel" parent="Panel/MarginContainer/VBoxContainer"]
unique_name_in_owner = true
layout_mode = 2
size_flags_vertical = 3
theme_override_constants/line_separation = 4
bbcode_enabled = true
scroll_following = true

[node name="StatusRow" type="HBoxContainer" parent="Panel/MarginContainer/VBoxContainer"]
layout_mode = 2

[node name="StatusLabel" type="Label" parent="Panel/MarginContainer/VBoxContainer/StatusRow"]
unique_name_in_owner = true
layout_mode = 2
text = "Ready"

[node name="InputRow" type="HBoxContainer" parent="Panel/MarginContainer/VBoxContainer"]
layout_mode = 2
theme_override_constants/separation = 10

[node name="InputField" type="LineEdit" parent="Panel/MarginContainer/VBoxContainer/InputRow"]
unique_name_in_owner = true
layout_mode = 2
size_flags_horizontal = 3
placeholder_text = "Type your message here..."

[node name="SendButton" type="Button" parent="Panel/MarginContainer/VBoxContainer/InputRow"]
unique_name_in_owner = true
layout_mode = 2
text = "Send"
