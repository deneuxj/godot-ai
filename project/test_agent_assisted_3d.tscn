model = "google/gemma-4-31b"
generated_code = "extends RefCounted

func build() -> Node3D:
	var root = Node3D.new()
	root.name = \"Sheep\"

	# Materials
	var wool_mat = StandardMaterial3D.new()
	wool_mat.albedo_color = Color(0.9, 0.9, 0.85) # Off-white
	
	var skin_mat = StandardMaterial3D.new()
	skin_mat.albedo_color = Color(0.15, 0.12, 0.1) # Dark brown/black

	# Body (The fluffy part)
	var body = create_mesh(SphereMesh.new(), wool_mat, Vector3(1.2, 1.0, 1.6), Vector3(0, 1, 0))
	root.add_child(body)

	# Head
	var head = create_mesh(SphereMesh.new(), skin_mat, Vector3(0.5, 0.5, 0.6), Vector3(1.4, 1.2, 0))
	root.add_child(head)

	# Eyes
	var eye_mat = StandardMaterial3D.new()
	eye_mat.albedo_color = Color(0, 0, 0)
	
	var left_eye = create_mesh(SphereMesh.new(), eye_mat, Vector3(0.1, 0.1, 0.1), Vector3(1.8, 1.3, 0.2))
	var right_eye = create_mesh(SphereMesh.new(), eye_mat, Vector3(0.1, 0.1, 0.1), Vector3(1.8, 1.3, -0.2))
	root.add_child(left_eye)
	root.add_child(right_eye)

	# Ears
	var ear_mesh = BoxMesh.new()
	ear_mesh.size = Vector3(0.1, 0.2, 0.3)
	
	var left_ear = create_mesh(ear_mesh, skin_mat, Vector3(1, 1, 1), Vector3(1.4, 1.5, 0.4))
	left_ear.rotation_degrees = Vector3(0, 0, -20)
	var right_ear = create_mesh(ear_mesh, skin_mat, Vector3(1, 1, 1), Vector3(1.4, 1.5, -0.4))
	right_ear.rotation_degrees = Vector3(0, 0, 20)
	root.add_child(left_ear)
	root.add_child(right_ear)

	# Legs
	var leg_mesh = CylinderMesh.new()
	leg_mesh.top_radius = 0.1
	leg_mesh.bottom_radius = 0.1
	leg_mesh.height = 0.6

	var legs_pos = [
		Vector3(0.6, 0.4, 0.5),   # Front Right
		Vector3(0.6, 0.4, -0.5),  # Front Left
		Vector3(-0.6, 0.4, 0.5),  # Back Right
		Vector3(-0.6, 0.4, -0.5)   # Back Left
	]

	for pos in legs_pos:
		var leg = create_mesh(leg_mesh, skin_mat, Vector3(1, 1, 1), pos)
		root.add_child(leg)

	return root

func create_mesh(mesh: Mesh, material: StandardMaterial3D, scale_vec: Vector3, position_vec: Vector3) -> MeshInstance3D:
	var mesh_instance = MeshInstance3D.new()
	mesh_instance.mesh = mesh
	
	# Set material to the first surface of the mesh
	var mat_override = StandardMaterial3D.new()
	mat_override.albedo_color = material.albedo_color
	mesh_instance.material_override = mat_override
	
	mesh_instance.scale = scale_vec
	mesh_instance.position = position_vec
	return mesh_instance"
