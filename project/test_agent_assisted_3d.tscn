generated_code = "extends RefCounted

func build() -> Node3D:
	var root = Node3D.new()
	root.name = \"House_Walls\"

	# Wall parameters
	var wall_height = 2.50
	var wall_thickness = 0.20

	# Helper function to create a wall segment
	var create_wall = func(start: Vector3, end: Vector3, name: String) -> MeshInstance3D:
		var diff = end - start
		var length = diff.length()
		
		if length < 0.01:
			return null

		var mid = start + diff / 2.0
		
		var mesh_inst = MeshInstance3D.new()
		mesh_inst.name = name
		mesh_inst.position = mid
		
		# Rotate to align with the segment
		var angle = atan2(diff.x, diff.z)
		mesh_inst.rotation.y = angle
		
		# Create a new mesh for this specific wall because BoxMesh size needs to be set per instance if lengths differ
		var box = BoxMesh.new()
		box.size = Vector3(wall_thickness, wall_height, length)
		mesh_inst.mesh = box
		
		return mesh_inst

	# Define the outer perimeter points based on the blueprint coordinates
	# Starting from bottom-left (approx 0,0) and moving clockwise
	var points = [
		Vector3(0, 0, 0),           # Bottom-left of Salle a manger
		Vector3(5.00, 0, 0),        # RE304 corner
