[node name="generate mouton" type="Node3D" parent="." unique_id=581335029]
script = ExtResource("1_d8ypf")
prompt = "Dessine-moi un mouton en 1000 lignes de code max."
generated_node_name = "Mouton"
model = "qwen/qwen3.6-35b-a3b"
generated_code = "extends RefCounted

# Matériaux partagés
var mat_corps: StandardMaterial3D
var mat_nez: StandardMaterial3D
var mat_oeil: StandardMaterial3D

func _init():
	# Initialisation des matériaux dans _init pour éviter de les recréer à chaque build
	mat_corps = StandardMaterial3D.new()
	mat_corps.albedo_color = Color(0.95, 0.95, 0.95)
	mat_corps.emission_enabled = true
	mat_corps.emission = Color(0.9, 0.9, 0.9)
	mat_corps.emission_energy = 0.1
	
	mat_nez = StandardMaterial3D.new()
	mat_nez.albedo_color = Color(0.2, 0.2, 0.2)
	
	mat_oeil = StandardMaterial3D.new()
	mat_oeil.albedo_color = Color(0.0, 0.0, 0.0)

func build() -> Node3D:
	var root = Node3D.new()
	root.name = \"Mouton\"

	# --- 1. Le Corps (Laine) ---
	var groupe_laine = Node3D.new()
	groupe_laine.name = \"Laine\"
	root.add_child(groupe_laine)
	
	# Corps principal (Sphère)
	var corps_mesh = SphereMesh.new()
	corps_mesh.radius = 1.0
	corps_mesh.height = 1.2
	var corps = MeshInstance3D.new()
	corps.name = \"Corps\"
	corps.position = Vector3(0, 1.2, 0)
	corps.mesh = corps_mesh
	corps.material_override = mat_corps
	groupe_laine.add_child(corps)
	
	# Boules de laine autour
	var boules_positions = [
		Vector3(0.8, 1.5, 0),
		Vector3(-0.8, 1.5, 0),
		Vector3(0, 1.8, 0.5),
		Vector3(0, 1.8, -0.5),
		Vector3(0.5, 1.2, 0.8),
		Vector3(-0.5, 1.2, 0.8),
		Vector3(0.5, 1.2, -0.8),
		Vector3(-0.5, 1.2, -0.8),
		Vector3(0.9, 1.0, 0.2),
		Vector3(-0.9, 1.0, 0.2),
		Vector3(0.9, 1.0, -0.2),
		Vector3(-0.9, 1.0, -0.2),
	]
	
	for pos in boules_positions:
		var b = SphereMesh.new()
		b.radius = 0.35
		b.height = 0.5
		var boules = MeshInstance3D.new()
		boules.name = \"BouleWool\"
		boules.position = pos
		boules.mesh = b
		boules.material_override = mat_corps
		groupe_laine.add_child(boules)

	# --- 2. La Tête ---
	var groupe_tete = Node3D.new()
	groupe_tete.name = \"Tete\"
	groupe_tete.position = Vector3(0, 2.0, 0.8)
	root.add_child(groupe_tete)
	
	# Crâne
	var tete_sph = SphereMesh.new()
	tete_sph.radius = 0.5
	tete_sph.height = 0.6
	var tete = MeshInstance3D.new()
	tete.name = \"Crane\"
	tete.position = Vector3(0, 0, 0)
	tete.mesh = tete_sph
	groupe_tete.add_child(tete)
	
	# Museau (Cylindre orienté)
	var museau_cyl = CylinderMesh.new()
	museau_cyl.top_radius = 0.2
	museau_cyl.bottom_radius = 0.15
	museau_cyl.height = 0.6
	var museau = MeshInstance3D.new()
	museau.name = \"Museau\"
	museau.position = Vector3(0, -0.1, 0.4)
	museau.mesh = museau_cyl
	museau.rotation_degrees = Vector3(90, 0, 0)
	museau.material_override = mat_corps
	groupe_tete.add_child(museau)
	
	# Nez
	var nez_sph = SphereMesh.new()
	nez_sph.radius = 0.08
	var nez = MeshInstance3D.new()
	nez.name = \"Nez\"
	nez.position = Vector3(0, 0, 0.7)
	nez.mesh = nez_sph
	nez.material_override = mat_nez
	groupe_tete.add_child(nez)
	
	# --- 3. Les Yeux ---
	var oeil_g = MeshInstance3D.new()
	oeil_g.name = \"OeilG\"
	oeil_g.position = Vector3(0.25, 0.1, 0.3)
	var oeil_mesh_g = SphereMesh.new()
	oeil_mesh_g.radius = 0.08
	oeil_mesh_g.height = 0.1
	oeil_g.mesh = oeil_mesh_g
	oeil_g.material_override = mat_oeil
	groupe_tete.add_child(oeil_g)
	
	var oeil_d = MeshInstance3D.new()
	oeil_d.name = \"OeilD\"
	oeil_d.position = Vector3(-0.25, 0.1, 0.3)
	var oeil_mesh_d = SphereMesh.new()
	oeil_mesh_d.radius = 0.08
	oeil_mesh_d.height = 0.1
	oeil_d.mesh = oeil_mesh_d
	oeil_d.material_override = mat_oeil
	groupe_tete.add_child(oeil_d)
	
	# --- 4. Les Oreilles ---
	var oreille_g = MeshInstance3D.new()
	oreille_g.name = \"OreilleG\"
	oreille_g.position = Vector3(0.4, 0.2, 0.1)
	var oreille_mesh_g = BoxMesh.new()
	oreille_mesh_g.size = Vector3(0.1, 0.3, 0.1)
	oreille_g.mesh = oreille_mesh_g
	oreille_g.rotation_degrees = Vector3(0, -45, 30)
	oreille_g.material_override = mat_corps
	groupe_tete.add_child(oreille_g)
	
	var oreille_d = MeshInstance3D.new()
	oreille_d.name = \"OreilleD\"
	oreille_d.position = Vector3(-0.4, 0.2, 0.1)
	var oreille_mesh_d = BoxMesh.new()
	oreille_mesh_d.size = Vector3(0.1, 0.3, 0.1)
	oreille_d.mesh = oreille_mesh_d
	oreille_d.rotation_degrees = Vector3(0, 45, -30)
	oreille_d.material_override = mat_corps
	groupe_tete.add_child(oreille_d)

	# --- 5. Les Pattes ---
	var groupe_pattes = Node3D.new()
	groupe_pattes.name = \"Pattes\"
	groupe_pattes.position = Vector3(0, 0.5, 0)
	root.add_child(groupe_pattes)
	
	var pattes_config = [
		{\"pos\": Vector3(0.6, 0.5, 0.4)},
		{\"pos\": Vector3(-0.6, 0.5, 0.4)},
		{\"pos\": Vector3(0.6, 0.5, -0.4)},
		{\"pos\": Vector3(-0.6, 0.5, -0.4)},
	]
	
	for cfg in pattes_config:
		var jambe_mesh = CylinderMesh.new()
		jambe_mesh.top_radius = 0.12
		jambe_mesh.bottom_radius = 0.1
		jambe_mesh.height = 1.0
		
		var patte = MeshInstance3D.new()
		patte.name = \"Patte\"
		patte.position = cfg[\"pos\"]
		patte.mesh = jambe_mesh
		groupe_pattes.add_child(patte)
		
		# Sabot
		var sabot_mesh = CylinderMesh.new()
		sabot_mesh.top_radius = 0.15
		sabot_mesh.bottom_radius = 0.15
		sabot_mesh.height = 0.1
		var sabot = MeshInstance3D.new()
		sabot.name = \"Sabot\"
		sabot.position = Vector3(0, -0.5, 0)
		sabot.mesh = sabot_mesh
		sabot.material_override = mat_nez
		patte.add_child(sabot)

	# --- 6. La Queue ---
	var queue_mesh = SphereMesh.new()
	queue_mesh.radius = 0.2
	queue_mesh.height = 0.3
	var queue = MeshInstance3D.new()
	queue.name = \"Queue\"
	queue.position = Vector3(0, 1.5, -1.0)
	queue.mesh = queue_mesh
	queue.material_override = mat_corps
	root.add_child(queue)
	
	# --- 7. Lumière ---
	var light = OmniLight3D.new()
	light.name = \"Light3D\"
	light.position = Vector3(5, 10, 5)
	light.light_color = Color(1, 1, 1)
	light.omni_range = 20
	root.add_child(light)

	return root"
metadata/_custom_type_script = "uid://fltqr6krppck"

