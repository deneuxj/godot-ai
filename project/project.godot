; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[ai]

openai/api_key="none"
openai/model="qwen/qwen3.6-35b-a3b"
openai/base_url="http://localhost:1234"
openai/max_tokens=16384

[animation]

compatibility/default_parent_skeleton_in_mesh_instance_3d=true

[application]

config/name="AI Assistant Project"
config/features=PackedStringArray("4.6")

[dotnet]

project/assembly_name="UnnamedProject"

[editor_plugins]

enabled=PackedStringArray("res://addons/ai_assistant/plugin.cfg")

[gd_resource type="ProjectSettings" format=3]

config_sections_enabled=["ai/openai"]
config_settings={}

[gdscript_format]

version=4
