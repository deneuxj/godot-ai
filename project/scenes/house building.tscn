"arguments": "{\"script_content\":\"extends EditorScript\\n\\nstatic func execute(node: Node):\\n\\t# Get the path to walls.txt\\n\\tvar walls_file_path = \\\"res://walls.txt\\\"\\n\\t\\n\\t# Read the contents of walls.txt\\n\\tvar file = FileAccess.open(walls_file_path, FileAccess.READ)\\n\\tif not file:\\n\\t\\tprint(\\\"Error: Could not open walls.txt\\\")\\n\\t\\treturn\\n\\t\\n\\tvar content = file.get_as_text()\\n\\tfile.close()\\n\\t\\n\\t# Split content into lines\\n\\tvar lines = content.split(\\\"\\\\n\\\")\\n\\t\\n\\t# Parse all wall data\\n\\tvar wall_count = 0\\n\\t\\n\\tfor i in range(lines.size()):\\n\\t\\tvar line = lines[i]\\n\\t\\t\\n\\t\\t# Look for wall number indicators (1., 2., etc.)\\n\\t\\tif line.begins_with((\\\"1.\\\", \\\"2.\\\", \\\"3.\\\", \\\"4.\\\")):\\n\\t\\t\\twall_count += 1\\n\\t\\t\\t\\n\\t\\t\\t# Extract wall name\\n\\t\\t\\tvar name_part = line.split(\\\" \\\")[1]\\n\\t\\t\\t\\n\\t\\t\\t# Find position line (usually 2 lines after)\\n\\t\\t\\tvar pos_line = \\\"\\\"\\n\\t\\t\\tif i + 2 < lines.size():\\n\\t\\t\\t\\tpos_line = lines[i + 2]\\n\\t\\t\\t\\n\\t\\t\\t# Find size line (usually 3 lines after)\\n\\t\\t\\tvar size_line = \\\"\\\"\\n\\t\\t\\tif i + 3 < lines.size():\\n\\t\\t\\t\\tsize_line = lines[i + 3]\\n\\t\\t\\t\\n\\t\\t\\t# Parse position\\n\\t\\t\\tvar position = Vector3(0, 0, 0)\\n\\t\\t\\tif pos_line.contains(\\\"Position:\\\"):\\n\\t\\t\\t\\tvar pos_str = pos_line.split(\\\":\\\")[1].strip_edges()\\n\\t\\t\\t\\tpos_str = pos_str.trim_prefix(\\\"(\\\").trim_suffix(\\\")\\\")\\n\\t\\t\\t\\tvar pos_values = pos_str.split(\\\",\\\")\\n\\t\\t\\t\\tif pos_values.size() >= 2:\\n\\t\\t\\t\\t\\tposition.x = float(pos_values[0])\\n\\t\\t\\t\\t\\tposition.z = float(pos_values[1])\\n\\t\\t\\t\\n\\t\\t\\t# Parse size\\n\\t\\t\\tvar size = Vector3(4.15, 2.5, 2.5)  # Default size\\n\\t\\t\\tif size_line.contains(\\\"Size:\\\"):\\n\\t\\t\\t\\tvar size_str = size_line.split(\\\":\\\")[1].strip_edges()\\n\\t\\t\\t\\tvar size_values = size_str.split(\\\"×\\\")\\n\\t\\t\\t\\tif size_values.size() >= 2:\\n\\t\\t\\t\\t\\tsize.x = float(size_values[0])\\n\\t\\t\\t\\t\\tsize.z = float(size_values[1])\\n\\t\\t\\t\\n\\t\\t\\t# Create wall node\\n\\t\\t\\tvar wall_node = MeshInstance3D.new()\\n\\t\\t\\twall_node.name = \\\"Wall_\\\" + name_part\\n\\t\\t\\t\\n\\t\\t\\t# Set the mesh (using a box mesh for simplicity)\\n\\t\\t\\tvar mesh = BoxMesh.new()\\n\\t\\t\\tmesh.size = size\\n\\t\\t\\twall_node.mesh = mesh\\n\\t\\t\\t\\n\\t\\t\\t# Set position\\n\\t\\t\\twall_node.position = position\\n\\t\\t\\t\\n\\t\\t\\t# Add to the scene with proper ownership\\n\\t\\t\\tnode.add_child(wall_node)\\n\\t\\t\\twall_node.owner = node.owner\\n\\t\\n\\tprint(\\\"Created \\\" + str(wall_count) + \\\" wall nodes\\\")\"}",
