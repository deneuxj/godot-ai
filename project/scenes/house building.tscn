"arguments": "{\"script_content\":\"extends EditorScript\\n\\nstatic func execute(node: Node):\\n\\t# Get the path to walls.txt\\n\\tvar walls_file_path = \\\"res://walls.txt\\\"\\n\\t\\n\\t# Read the contents of walls.txt\\n\\tvar file = FileAccess.open(walls_file_path, FileAccess.READ)\\n\\tif not file:\\n\\t\\tprint(\\\"Error: Could not open walls.txt\\\")\\n\\t\\treturn\\n\\t\\n\\tvar content = file.get_as_text()\\n\\tfile.close()\\n\\t\\n\\t# Split content into lines\\n\\tvar lines = content.split(\\\"\\\\n\\\")\\n\\t\\n\\t# Find the section with wall data\\n\\tvar in_wall_section = false\\n\\tvar wall_data = []\\n\\t\\n\\tfor line in lines:\\n\\t\\tif line.begins_with(\\\"---\\\"):\\n\\t\\t\\tin_wall_section = true\\n\\t\\t\\tcontinue\\n\\t\\telif line.begins_with(\\\"TOTAL WALLS\\\") or line.strip_edges() == \\\"\\\":\\n\\t\\t\\tin_wall_section = false\\n\\t\\t\\tcontinue\\n\\t\\t\\n\\t\\tif in_wall_section and line.begins_with((\\\"1.\\\", \\\"2.\\\", \\\"3.\\\", \\\"4.\\\")):\\n\\t\\t\\t# Parse wall information\\n\\t\\t\\tvar wall_info = {\\n\\t\\t\\t\\t\\\"name\\\": line.split(\\\" \\\")[1],\\n\\t\\t\\t\\t\\\"position\\\": Vector3.ZERO,\\n\\t\\t\\t\\t\\\"size\\\": Vector3.ZERO\\n\\t\\t\\t}\\n\\t\\t\\t\\n\\t\\t\\t# Extract position from the next line\\n\\t\\t\\tvar pos_line = lines[lines.find(line) + 2]\\n\\t\\t\\tif pos_line.contains(\\\"Position:\\\"):\\n\\t\\t\\t\\tvar pos_str = pos_line.split(\\\":\\\")[1].strip_edges()\\n\\t\\t\\t\\tpos_str = pos_str.trim_prefix(\\\"(\\\").trim_suffix(\\\")\\\")\\n\\t\\t\\t\\tvar pos_values = pos_str.split(\\\",\\\")\\n\\t\\t\\t\\twall_info.position = Vector3(\\n\\t\\t\\t\\t\\tfloat(pos_values[0]),\\n\\t\\t\\t\\t\\t0.0,\\n\\t\\t\\t\\t\\tfloat(pos_values[1])\\n\\t\\t\\t\\t)\\n\\t\\t\\t\\n\\t\\t\\t# Extract size from the next line\\n\\t\\t\\tvar size_line = lines[lines.find(line) + 3]\\n\\t\\t\\tif size_line.contains(\\\"Size:\\\"):\\n\\t\\t\\t\\tvar size_str = size_line.split(\\\":\\\")[1].strip_edges()\\n\\t\\t\\t\\tvar size_values = size_str.split(\\\"×\\\")\\n\\t\\t\\t\\twall_info.size = Vector3(\\n\\t\\t\\t\\t\\tfloat(size_values[0]),\\n\\t\\t\\t\\t\\t2.5,\\n\\t\\t\\t\\t\\tfloat(size_values[1])\\n\\t\\t\\t\\t)\\n\\t\\t\\t\\n\\t\\t\\twall_data.append(wall_info)\\n\\t\\n\\t# Create nodes for each wall\\n\\tfor wall in wall_data:\\n\\t\\tvar wall_node = MeshInstance3D.new()\\n\\t\\twall_node.name = \\\"Wall_\\\" + wall.name\\n\\t\\t\\n\\t\\t# Set the mesh (using a box mesh for simplicity)\\n\\t\\tvar mesh = BoxMesh.new()\\n\\t\\tmesh.size = wall.size\\n\\t\\twall_node.mesh = mesh\\n\\t\\t\\n\\t\\t# Set position\\n\\t\\twall_node.position = wall.position\\n\\t\\t\\n\\t\\t# Set owner to the scene root node's owner, not this AI node\\n\\t\\tvar scene_root = node.get_tree().get_root()\\n\\t\\tif scene_root and scene_root.owner:\\n\\t\\t\\twall_node.owner = scene_root.owner\\n\\t\\t\\n\\t\\t# Add as child to the current node (or its owner if needed)\\n\\t\\tnode.add_child(wall_node)\\n\\t\\twall_node.set_owner(node.owner)\\n\\t\\n\\tprint(\\\"Created \\\" + str(wall_data.size()) + \\\" wall nodes\\\")\"}",
