t\\t\\\"depth\\\": 1.50,\\n\\t\\t\\t\\\"pos_x\\\": 10.0,\\n\\t\\t\\t\\\"pos_y\\\": 10.0\\n\\t\\t},\\n\\t\\t\\\"ENTREE\\\": {\\n\\t\\t\\t\\\"width\\\": 3.00,\\n\\t\\t\\t\\\"depth\\\": 3.00,\\n\\t\\t\\t\\\"pos_x\\\": 15.0,\\n\\t\\t\\t\\\"pos_y\\\": 10.0\\n\\t\\t},\\n\\t\\t\\\"BUREAU\\\": {\\n\\t\\t\\t\\\"width\\\": 1.50,\\n\\t\\t\\t\\\"depth\\\": 2.00,\\n\\t\\t\\t\\\"pos_x\\\": 20.0,\\n\\t\\t\\t\\\"pos_y\\\": 10.0\\n\\t\\t}\\n\\t}\\n\\t\\n\\t# Height for the thin box (representing floor height)\\n\\tvar box_height := 0.05  # 5cm thin horizontal box\\n\\t\\n\\t# Create a container node to hold all room boxes\\n\\tvar rooms_container := Node3D.new()\\n\\trooms_container.name = \\\"Rooms\\\"\\n\\t\\n\\t# IMPORTANT: Add to tree FIRST before setting owner\\n\\tnode.add_child(rooms_container)\\n\\t\\n\\t# Now set the owner AFTER adding to tree\\n\\trooms_container.set_owner(owner_node)\\n\\t\\n\\t# Create each room node\\n\\tfor room_name in rooms:\\n\\t\\tvar room_data = rooms[room_name]\\n\\t\\t\\n\\t\\t# Create MeshInstance3D for the room\\n\\t\\tvar room_box := MeshInstance3D.new()\\n\\t\\troom_box.name = room_name\\n\\t\\t\\n\\t\\t# Create the box mesh\\n\\t\\tvar box_mesh := BoxMesh.new()\\n\\t\\tbox_mesh.set_size(Vector3(room_data[\\\"width\\\"], box_height, room_data[\\\"depth\\\"]))\\n\\t\\troom_box.set_mesh(box_mesh)\\n\\t\\t\\n\\t\\t# Position the box (centered on the position)\\n\\t\\troom_box.position = Vector3(\\n\\t\\t\\troom_data[\\\"pos_x\\\"] + room_data[\\\"width\\\"] / 2.0,\\n\\t\\t\\t0.0,\\n\\t\\t\\troom_data[\\\"pos_y\\\"] + room_data[\\\"depth\\\"] / 2.0\\n\\t\\t)\\n\\t\\t\\n\\t\\t# Add to the container (which is already in the tree)\\n\\t\\trooms_container.add_child(room_box)\\n\\t\\t\\n\\t\\t# Set owner AFTER adding to tree\\n\\t\\troom_box.set_owner(owner_node)\\n\\t\\n\\tprint(\\\"Created\\\", len(rooms), \\\"room nodes.\\\")\\n\\tprint(\\\"All nodes have owner set to:\\\", owner_node.name if owner_node != null else \\\"null\\\")\\n\"}",
